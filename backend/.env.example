# ──────────────────────────────────────────────────
# Duo Designs Backend — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Client URLs (CORS origins) ─────────────────────
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ── MongoDB Atlas ──────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/duodesigns

# ── JWT Authentication ─────────────────────────────
JWT_SECRET=your_64_char_random_string_here
JWT_REFRESH_SECRET=another_64_char_random_string_here

# ── Razorpay Payment Gateway ──────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXX
RAZORPAY_KEY_SECRET=XXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXX

# ── Gmail SMTP (Email Service) ────────────────────
SMTP_EMAIL=support@duodesigns.in
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Cloudinary (Image Storage) ────────────────────
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx

# ── Sentry (Error Tracking) ──────────────────────
SENTRY_DSN=

# ── GST / Tax ─────────────────────────────────────
SELLER_STATE=Karnataka
SELLER_GSTIN=29XXXXXXXXXXXXX

# ── Render Keep-Alive (Production Only) ───────────
# Set this to your Render external URL in production
# e.g. https://duo-designs-api.onrender.com
KEEP_ALIVE_URL=
