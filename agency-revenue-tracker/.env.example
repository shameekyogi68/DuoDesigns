# ──────────────────────────────────────────────────
# Agency Revenue Tracker — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────

# ── API Configuration ─────────────────────────────
VITE_DUO_API_URL=http://localhost:5000/api

# ── Agency Credentials ────────────────────────────
VITE_AGENCY_EMAIL=you@youragency.com
VITE_AGENCY_PASSWORD_HASH=bcrypt_hash_here

# ── Business Configuration ────────────────────────
VITE_COMMISSION_RATE=0.05
VITE_SYNC_INTERVAL=300000

# ── App Details ───────────────────────────────────
VITE_APP_NAME=Revenue Tracker
VITE_APP_VERSION=1.0.0
