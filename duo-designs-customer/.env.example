# ──────────────────────────────────────────────────
# Duo Designs Customer App — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────

# ── API Configuration ─────────────────────────────
VITE_API_URL=http://localhost:5000/api

# ── Payment Configuration ─────────────────────────
VITE_RAZORPAY_KEY=your_razorpay_key_here

# ── Asset Management ──────────────────────────────
VITE_CLOUDINARY_URL=your_cloudinary_url_here

# ── App Details ───────────────────────────────────
VITE_APP_NAME=Duo Designs
VITE_SELLER_STATE=Karnataka
